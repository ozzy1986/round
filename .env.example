# Telegram bot (from BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# PostgreSQL: use DATABASE_URL or individual vars (password empty for local trust).
# With PgBouncer on VPS use PG_PORT=6432 and point to 127.0.0.1.
# DATABASE_URL=postgresql://postgres@127.0.0.1:5432/round
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=round
PG_PASSWORD=
PG_DATABASE=round
# Connection pool size. With PgBouncer use 20–50 per process; at scale set REDIS_URL.
# PG_POOL_MAX=10
# PG_STMT_TIMEOUT_MS=10000

# Server
PORT=3001
HOST=127.0.0.1
# SHUTDOWN_TIMEOUT_MS=10000

# Rate limit: per-user when Bearer present, else per-IP. Redis required for multi-instance.
# RATE_LIMIT_MAX=200
# RATE_LIMIT_WINDOW=1 minute

# JWT for anonymous auth (min 32 characters)
JWT_SECRET=your-random-secret-min-32-chars

# Bot-only: secret for /auth/telegram (so bot can get JWT for Telegram users)
# BOT_SECRET=your-bot-secret

# CORS: comma-separated origins (e.g. https://round.ozzy1986.com).
# Empty = deny CORS in production, allow all in local dev.
# CORS_ORIGINS=https://round.ozzy1986.com

# Redis. Required for production at scale (rate limit shared across API instances). Bot caches use it too.
# REDIS_URL=redis://127.0.0.1:6379

# Sentry (optional). When set, 5xx errors are reported. Free tier: 5K events/month.
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Bug report email alerts (optional). If unset, reports are still stored in PostgreSQL.
# Use local Postfix (no auth): SMTP_HOST=127.0.0.1 SMTP_PORT=25 BUG_REPORT_RECIPIENT=your@email.com
# Or external SMTP (auth): set SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS, BUG_REPORT_RECIPIENT
# For Timeweb-hosted mailboxes use smtp.timeweb.ru with SMTP_PORT=2525 (or 465 with SMTP_SECURE=true),
# SMTP_USER=mailbox@your-domain, SMTP_PASS=mailbox_password, and SMTP_FROM matching SMTP_USER.
# Direct VPS delivery to Gmail over port 25 is often blocked by providers, so prefer an authenticated relay.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=round@example.com
# BUG_REPORT_RECIPIENT=ozeritski@gmail.com
# SMTP_INSECURE=false

# Bug report Telegram alerts (optional). The chat must start the bot at least once.
# Set one chat:
# BUG_REPORT_TELEGRAM_CHAT_ID=123456789
# Or multiple chats/channels:
# BUG_REPORT_TELEGRAM_CHAT_IDS=123456789,-1001234567890
# Optional override for the Telegram API base or request timeout:
# TELEGRAM_API_BASE=https://api.telegram.org
# BUG_REPORT_TELEGRAM_TIMEOUT_MS=5000

# Admin bug report inspector (HTTP Basic auth at /admin/bug-reports)
# ADMIN_BASIC_USER=admin
# ADMIN_BASIC_PASSWORD=change-me

# Google Cloud TTS (free tier: Standard voices). Optional for Telegram bot.
# Set path to service account JSON or use default credentials.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
