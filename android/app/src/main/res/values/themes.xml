<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Round" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">#1A1110</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
    <style name="Theme.Round.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#1A1110</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.Round</item>
    </style>
</resources>
