{
  "name": "raund",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/src/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && node --input-type=module -e \"import { cpSync } from 'node:fs'; cpSync('src/i18n','dist/src/i18n',{recursive:true})\"",
    "start": "node dist/src/server.js",
    "dev": "tsx watch src/server.ts",
    "bot": "tsx src/bot/run.ts",
    "test": "vitest run",
    "test:unit": "vitest run tests/timer-engine tests/bot tests/i18n tests/cache.test.ts tests/auth/rate-limit.test.ts tests/routes/profiles.validation.test.ts",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "migrate:up": "tsx scripts/run-migrate.ts up",
    "migrate:down": "tsx scripts/run-migrate.ts down",
    "migrate:create": "node-pg-migrate create",
    "purge:tokens": "tsx scripts/purge-tokens.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Interval timer for boxing, MMA, HIIT, running",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@google-cloud/text-to-speech": "^6.4.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "ioredis": "^5.9.3",
    "pg": "^8.18.0",
    "telegraf": "^4.16.3",
    "@sentry/node": "^8.50.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^2.1.6",
    "node-pg-migrate": "^6.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.6"
  }
}